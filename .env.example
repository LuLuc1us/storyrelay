PORT=3000
HOST=127.0.0.1

# 设置后会启用真实 AI 主持人；不设置则使用本地占位逻辑。
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# 可选：设置 AI_PROVIDER=openrouter 时使用 OpenRouter。
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# 可选：设置 AI_PROVIDER=openai 时使用 OpenAI。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
