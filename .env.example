PORT=3000
HOST=127.0.0.1

# 设置后会启用真实 AI 主持人；不设置则使用本地占位逻辑。
AI_PROVIDER=gemini
AI_TIMEOUT_MS=12000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# 可选：设置 AI_PROVIDER=openrouter 时使用 OpenRouter。
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# 可选：Groq 可作为 OpenRouter 的备用通道。
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
AI_FALLBACK_PROVIDERS=openrouter,groq,gemini,openai

# 可选：设置 AI_PROVIDER=openai 时使用 OpenAI。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# 可选：设置后房间和故事会保存到 Supabase，服务重启后可以恢复。
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ROOMS_TABLE=story_rooms

# 可选：自动清理旧房间，避免测试房间长期堆在 Supabase。
ROOM_ACTIVE_RETENTION_HOURS=72
ROOM_FINISHED_RETENTION_DAYS=14
ROOM_ABANDONED_LOBBY_HOURS=12
